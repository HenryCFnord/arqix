#!/usr/bin/env python3
"""Python reference implementation of the arqix command surface.

Dispatcher mirroring the Rust binary's command tree (ADR-0005): implemented
command families are delegated to their oracle module; everything else
exits with code 70, exactly like the Rust stubs, so this script can stand
in for the binary via the ARQIX_BIN override in the test harness.

Implemented here (per the oracle policy in arc42 chapter 8):
  trace scan|check|coverage|matrix  -> arqix_trace.py
  verify                            -> sequencer over the checker scripts

Everything else is deliberately NOT implemented in Python (parser/fmt/
finalise, publish/render, mcp live in Rust only).

`verify` sequences the repository gate: the checker selftests, the
Python reference checkers, the report-freshness check, cargo-test
(skipped when no Cargo.toml is present), the product's own
`arqix verify` (dogfooded whenever a binary exists; it runs format,
lint, trace-scan, coverage, and ratchet per the configured policy,
with coverage informational while the corpus is under construction),
and markdownlint.
"""

import json
import shutil
import subprocess
import sys
from pathlib import Path

SCRIPT_DIR = Path(__file__).resolve().parent
sys.path.insert(0, str(SCRIPT_DIR))

EXIT_UNIMPLEMENTED = 70


def split_options(argv):
    """Extract the global --format flag from the argument list. Command-
    specific flags (verify's --fail-fast/--aggregate) stay in `rest` and are
    parsed by their command — the Rust binary rejects them anywhere else
    with a usage error, so the stand-in must too."""
    fmt = "text"
    rest = []
    i = 0
    while i < len(argv):
        arg = argv[i]
        if arg == "--format":
            if i + 1 >= len(argv):
                print("error: --format requires a value", file=sys.stderr)
                sys.exit(2)
            fmt = argv[i + 1]
            i += 2
            continue
        if arg.startswith("--format="):
            fmt = arg.split("=", 1)[1]
            i += 1
            continue
        rest.append(arg)
        i += 1
    if fmt not in ("text", "json"):
        print(f"error: invalid value '{fmt}' for --format", file=sys.stderr)
        sys.exit(2)
    return fmt, rest


def run_step(name, argv):
    proc = subprocess.run(argv, capture_output=True, text=True)
    return {"step": name, "exit_code": proc.returncode, "ok": proc.returncode == 0,
            "output": (proc.stdout + proc.stderr).strip()}


# Pinned so the gate is reproducible: an unpinned `npx --yes` would silently
# float to whatever version npm serves that day.
MARKDOWNLINT_CLI2 = "markdownlint-cli2@0.23.0"


def snapshot_strategy():
    """`[policies.reports] snapshot-strategy` (C17): how the freshness gate
    treats the committed snapshots. `committed` gates everywhere (default),
    `main-only` gates only on the default branch, `on-demand` never gates."""
    import os
    path = Path("arqix.toml")
    strategy = "committed"
    if path.is_file():
        import tomllib
        try:
            config = tomllib.loads(path.read_text(encoding="utf-8"))
            strategy = (config.get("policies", {}).get("reports", {})
                        .get("snapshot-strategy", "committed"))
        except tomllib.TOMLDecodeError:
            pass
    if strategy == "main-only":
        branch = os.environ.get("GITHUB_REF_NAME")
        if branch is None:
            probe = subprocess.run(["git", "rev-parse", "--abbrev-ref", "HEAD"],
                                   capture_output=True, text=True)
            branch = probe.stdout.strip() if probe.returncode == 0 else ""
        return "committed" if branch in ("main", "master") else "on-demand"
    return strategy


def arqix_binary():
    """The Rust binary for the dogfooded verify step: the ARQIX_BIN
    override, or the debug build if present."""
    import os
    override = os.environ.get("ARQIX_BIN")
    if override and Path(override).is_file():
        # Never dogfood ourselves: an ARQIX_BIN pointing back at this
        # dispatcher (the conformance harness does that) would recurse
        # through the verify step forever — fall through to the build.
        if Path(override).resolve() != Path(__file__).resolve():
            return override
    default = Path("target/debug/arqix")
    return str(default) if default.is_file() else None


def verify(fmt, fail_fast):
    """Sequence the repository gate (approximates REQ-04-01-05-01..03)."""
    python = sys.executable
    steps = [
        # The load-bearing checkers prove themselves first: a checker whose
        # own selftest fails must not be trusted to gate anything.
        ("selftest-frontmatter",
         [python, str(SCRIPT_DIR / "check_frontmatter.py"), "--selftest"], True),
        ("selftest-requirements",
         [python, str(SCRIPT_DIR / "check_requirements.py"), "--selftest"], True),
        ("selftest-trace-markers",
         [python, str(SCRIPT_DIR / "check_trace_markers.py"), "--selftest"], True),
        ("selftest-trace-oracle",
         [python, str(SCRIPT_DIR / "arqix_trace.py"), "--selftest"], True),
        ("selftest-report",
         [python, str(SCRIPT_DIR / "arqix_report.py"), "--selftest"], True),
        # The frontmatter and requirements checkers are ported and conformant
        # (scripts/check_conformance.py), so their Python oracles are demoted
        # to that cross-check and no longer gate the corpus here — exactly as
        # the trace oracle has no gating step (arc42 ch8 oracle policy). The
        # Rust ports gate instead, via the dogfooded `arqix verify` step below.
        # Their selftests stay: they prove the oracles the cross-check compares
        # against, mirroring selftest-trace-oracle.
        ("trace-markers", [python, str(SCRIPT_DIR / "check_trace_markers.py")], True),
    ]
    if snapshot_strategy() != "on-demand":
        steps.append(
            ("report-freshness",
             [python, str(SCRIPT_DIR / "arqix_report.py"), "--check"], True))

    if Path("Cargo.toml").exists():
        steps.append(("cargo-test", ["cargo", "test", "--quiet"], True))
    if binary := arqix_binary():
        # Dogfooding (roadmap phase 5, owner decision 2026-07-11): the
        # product's own orchestrator gates the corpus checks — format,
        # lint (including the frontmatter and requirements checkers, now
        # product-owned), trace-scan, and the coverage ratchet, with
        # coverage informational per the configured [policies.verify]. The
        # Python steps above stay only for what the product does not own as
        # a gate yet: the marker gate and the report snapshots, plus the
        # selftests that prove the oracles the conformance cross-check still
        # compares against.
        steps.append(("arqix-verify", [binary, "verify"], True))
    if shutil.which("npx"):
        # Markdown hygiene per .markdownlint.jsonc (ADR-0009 documentation
        # policy). Skipped where Node/npx is unavailable, like cargo-test.
        steps.append(("markdownlint", ["npx", "--yes", MARKDOWNLINT_CLI2], True))

    results = []
    failed = False
    for name, argv, gating in steps:
        result = run_step(name, argv)
        result["gating"] = gating
        results.append(result)
        if gating and not result["ok"]:
            failed = True
            if fail_fast:
                break

    if fmt == "json":
        print(json.dumps({"steps": results, "ok": not failed}, indent=2))
    else:
        for r in results:
            status = "ok" if r["ok"] else ("FAIL" if r["gating"] else "info")
            print(f"{status:4} {r['step']} (exit {r['exit_code']})")
            if not r["ok"] and r["output"]:
                # Gating failures show everything; informational steps
                # (trace coverage during implementation) only their summary.
                lines = r["output"].splitlines()
                if not r["gating"]:
                    lines = [l for l in lines if not l.startswith("|")]
                print("     " + "\n     ".join(lines))
        print(f"verify: {'ok' if not failed else 'FAILED'} "
              f"({sum(1 for r in results if r['ok'])}/{len(results)} steps ok)")
    return 1 if failed else 0


def unimplemented(command):
    print(f"error: `arqix {command}` is not implemented yet", file=sys.stderr)
    return EXIT_UNIMPLEMENTED


def main():
    fmt, args = split_options(sys.argv[1:])
    if not args:
        print("error: a subcommand is required", file=sys.stderr)
        return 2

    command, rest = args[0], args[1:]

    if command == "trace":
        if not rest:
            print("error: a trace verb is required", file=sys.stderr)
            return 2
        import arqix_trace
        return arqix_trace.run(rest[0], rest[1:], fmt)

    if command == "verify":
        fail_fast = False
        for arg in rest:
            if arg == "--fail-fast":
                fail_fast = True
            elif arg == "--aggregate":
                fail_fast = False
            else:
                print(f"error: unexpected argument '{arg}' for verify", file=sys.stderr)
                return 2
        return verify(fmt, fail_fast)

    known = {
        "config", "doc", "unit", "fmt", "finalise", "lint", "assemble",
        "report", "publish", "render", "policy", "mcp",
    }
    if command in known:
        return unimplemented(command)

    print(f"error: unrecognized subcommand '{command}'", file=sys.stderr)
    return 2


if __name__ == "__main__":
    sys.exit(main())
