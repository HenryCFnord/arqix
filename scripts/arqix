#!/usr/bin/env python3
"""The repository gate sequencer.

Historically this was the dispatcher over the Python reference oracles
(trace, marker gate, report units, and the frontmatter/requirements
checkers). Those oracles retired on 2026-07-15 (task #78, arc42 chapter 8
oracle policy): every contract they carried passed its conformance suite,
their selftest fixtures are mirrored in the Rust test suite, and the Rust
binary owns the checks. See git history for the retired scripts.

What remains is the one-command daily gate:

    python3 scripts/arqix verify

sequences cargo-test (skipped when no Cargo.toml is present), the
product's own `arqix verify` (the authoritative corpus gate: format,
lint including the frontmatter/requirements checkers, trace-scan,
coverage/ratchet/freshness per the configured [policies.verify], the
marker gate, and the strategy-aware report-freshness check), and
markdownlint. Every other subcommand belongs to the Rust binary.
"""

import json
import shutil
import subprocess
import sys
from pathlib import Path

SCRIPT_DIR = Path(__file__).resolve().parent


def split_options(argv):
    """Extract the global --format flag from the argument list. Command-
    specific flags (verify's --fail-fast/--aggregate) stay in `rest` and are
    parsed by their command — the Rust binary rejects them anywhere else
    with a usage error, so the stand-in must too."""
    fmt = "text"
    rest = []
    i = 0
    while i < len(argv):
        arg = argv[i]
        if arg == "--format":
            if i + 1 >= len(argv):
                print("error: --format requires a value", file=sys.stderr)
                sys.exit(2)
            fmt = argv[i + 1]
            i += 2
            continue
        if arg.startswith("--format="):
            fmt = arg.split("=", 1)[1]
            i += 1
            continue
        rest.append(arg)
        i += 1
    if fmt not in ("text", "json"):
        print(f"error: invalid value '{fmt}' for --format", file=sys.stderr)
        sys.exit(2)
    return fmt, rest


def run_step(name, argv):
    proc = subprocess.run(argv, capture_output=True, text=True)
    return {"step": name, "exit_code": proc.returncode, "ok": proc.returncode == 0,
            "output": (proc.stdout + proc.stderr).strip()}


# Pinned so the gate is reproducible: an unpinned `npx --yes` would silently
# float to whatever version npm serves that day.
MARKDOWNLINT_CLI2 = "markdownlint-cli2@0.23.0"


def arqix_binary():
    """The Rust binary for the dogfooded verify step: the ARQIX_BIN
    override, or the debug build if present."""
    import os
    override = os.environ.get("ARQIX_BIN")
    if override and Path(override).is_file():
        # Never dogfood ourselves: an ARQIX_BIN pointing back at this
        # sequencer would recurse through the verify step forever — fall
        # through to the build.
        if Path(override).resolve() != Path(__file__).resolve():
            return override
    default = Path("target/debug/arqix")
    return str(default) if default.is_file() else None


def verify(fmt, fail_fast):
    """Sequence the repository gate (approximates REQ-04-01-05-01..03)."""
    steps = []
    if Path("Cargo.toml").exists():
        steps.append(("cargo-test", ["cargo", "test", "--quiet"], True))
    if binary := arqix_binary():
        # The product's own orchestrator is the authoritative corpus gate
        # (roadmap phase 5, oracle retirement 2026-07-15): format, lint
        # including the frontmatter and requirements checkers, trace-scan,
        # coverage/ratchet/freshness per the configured [policies.verify],
        # the marker gate, and the strategy-aware report-freshness check.
        steps.append(("arqix-verify", [binary, "verify"], True))
    else:
        # Without a built binary the corpus checks cannot run, and a gate
        # that silently skips them would report a false green (the retired
        # Python steps used to cover this case). Fail hard instead; CI
        # builds the binary first, so this only fires for un-built local
        # checkouts.
        print(
            "error: no arqix binary (build with `cargo build` or set ARQIX_BIN); "
            "the corpus checks cannot run, so the gate fails",
            file=sys.stderr,
        )
        steps.append(
            ("arqix-verify",
             [sys.executable, "-c",
              "import sys; print('no arqix binary: corpus checks not run'); sys.exit(1)"],
             True))
    if shutil.which("npx"):
        # Markdown hygiene per .markdownlint.jsonc (ADR-0009 documentation
        # policy). Skipped where Node/npx is unavailable, like cargo-test.
        steps.append(("markdownlint", ["npx", "--yes", MARKDOWNLINT_CLI2], True))

    results = []
    failed = False
    for name, argv, gating in steps:
        result = run_step(name, argv)
        result["gating"] = gating
        results.append(result)
        if gating and not result["ok"]:
            failed = True
            if fail_fast:
                break

    if fmt == "json":
        print(json.dumps({"steps": results, "ok": not failed}, indent=2))
    else:
        for r in results:
            status = "ok" if r["ok"] else ("FAIL" if r["gating"] else "info")
            print(f"{status:4} {r['step']} (exit {r['exit_code']})")
            if not r["ok"] and r["output"]:
                # Gating failures show everything; informational steps
                # (trace coverage during implementation) only their summary.
                lines = r["output"].splitlines()
                if not r["gating"]:
                    lines = [l for l in lines if not l.startswith("|")]
                print("     " + "\n     ".join(lines))
        print(f"verify: {'ok' if not failed else 'FAILED'} "
              f"({sum(1 for r in results if r['ok'])}/{len(results)} steps ok)")
    return 1 if failed else 0


def main():
    fmt, args = split_options(sys.argv[1:])
    if not args:
        print("error: a subcommand is required", file=sys.stderr)
        return 2

    command, rest = args[0], args[1:]

    if command == "verify":
        fail_fast = False
        for arg in rest:
            if arg == "--fail-fast":
                fail_fast = True
            elif arg == "--aggregate":
                fail_fast = False
            else:
                print(f"error: unexpected argument '{arg}' for verify", file=sys.stderr)
                return 2
        return verify(fmt, fail_fast)

    print(
        f"error: `arqix {command}` lives in the Rust binary "
        "(cargo build; target/debug/arqix) — this sequencer only runs `verify`",
        file=sys.stderr,
    )
    return 2


if __name__ == "__main__":
    sys.exit(main())
